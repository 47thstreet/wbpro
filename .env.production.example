# =============================================================================
# WBPro (WhatsApp Bot Pro) — Production Environment Variables
# Copy to .env and fill in all values before deploying.
# =============================================================================

# --- Server ---
# Port to listen on (default: 8080)
PORT=8080

# --- Authentication ---
# Password for the WBPro admin dashboard login
WBPRO_PASSWORD=
# JWT secret for signing session tokens (generate: openssl rand -hex 32)
JWT_SECRET=

# --- Kartis Integration ---
# Base URL of the Kartis ticketing platform
KARTIS_URL=https://kartis.app
# Full URL to the Kartis public events API (auto-derived from KARTIS_URL if not set)
KARTIS_EVENTS_URL=https://kartis.app/api/cms/public-events
# Shared secret for verifying inbound Kartis webhook signatures
KARTIS_WEBHOOK_SECRET=

# --- Public URLs ---
# Public URL of this WBPro instance (used for webhook registration)
WBPRO_URL=https://wbpro.example.com
# Public URL of the TBP marketing website (used in message templates)
TBP_URL=https://tbp.example.com

# --- Scheduling (optional) ---
# Minimum minutes between messages to the same group (default: 30)
COOLDOWN_MINUTES=30
# Quiet hours — no messages sent during this window (24h format, default: 02:00-10:00)
QUIET_START=02:00
QUIET_END=10:00
